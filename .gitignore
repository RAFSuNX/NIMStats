# .gitignore for NIM Benchmarking Dashboard

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
.vscode/

# Node (if you add npm packages later)
node_modules/
package-lock.json
yarn.lock

# IDE
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Legacy JSON history (replaced by history.db)
history.json

# Temporary benchmark output files
scripts/results*.json

# Python
__pycache__/
*.pyc

# DB lives on data branch, not main
history.db

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
